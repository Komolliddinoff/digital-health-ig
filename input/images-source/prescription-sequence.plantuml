@startuml prescription-sequence
title e-Prescription to dispensing
autonumber

actor "Prescriber" as Doc
participant "DHP\nFHIR server" as DHP
actor "Pharmacist" as Pharm
participant "SHIF" as SHIF

Doc -> DHP : POST MedicationRequest\n(subject -> [[StructureDefinition-uz-core-patient.html Patient]], reason -> [[StructureDefinition-uz-core-condition.html Condition]])
note over Doc : prescription printed with a QR code

Pharm -> DHP : scan QR -> GET MedicationRequest
Pharm -> DHP : POST MedicationDispense\n(authorizingPrescription -> MedicationRequest)

DHP -> SHIF : MedicationRequest + MedicationDispense\n(async, for reimbursement)
note over SHIF : SHIF adjudicates and pays\nin its own system
@enduml
