# A concise description of what this element means (e.g. for use in autogenerated summaries).
#: StructureDefinition.element.Specimen.identifier/short
msgid "Specimen identifier used by the source system (e.g., LIS). Enables tracking, matching, and referencing the specimen across systems."
msgstr "Specimen identifier used by the source system (e.g., LIS). Enables tracking, matching, and referencing the specimen across systems."

# A concise description of what this element means (e.g. for use in autogenerated summaries).
#: StructureDefinition.element.Specimen.accessionIdentifier/short
msgid "Laboratory accession identifier assigned when the specimen is accepted/registered by the laboratory. Used to link the specimen to lab workflows and results."
msgstr "Laboratory accession identifier assigned when the specimen is accepted/registered by the laboratory. Used to link the specimen to lab workflows and results."

# A concise description of what this element means (e.g. for use in autogenerated summaries).
#: StructureDefinition.element.Specimen.status/short
msgid "Current lifecycle status of the specimen (e.g., available, unavailable)."
msgstr "Current lifecycle status of the specimen (e.g., available, unavailable)."

# A concise description of what this element means (e.g. for use in autogenerated summaries).
#: StructureDefinition.element.Specimen.type/short
msgid "Type of specimen (e.g., venous blood, urine, swab) used to interpret tests and processing requirements."
msgstr "Type of specimen (e.g., venous blood, urine, swab) used to interpret tests and processing requirements."

# A concise description of what this element means (e.g. for use in autogenerated summaries).
#: StructureDefinition.element.Specimen.subject/short
msgid "Where the specimen came from. This may be from patient(s), from a location (e.g., the source of an environmental sample), or a sampling of a substance."
msgstr "Where the specimen came from. This may be from patient(s), from a location (e.g., the source of an environmental sample), or a sampling of a substance."

# A concise description of what this element means (e.g. for use in autogenerated summaries).
#: StructureDefinition.element.Specimen.receivedTime/short
msgid "Date/time the specimen was received by the laboratory/performing organization. Supports turnaround-time and traceability."
msgstr "Date/time the specimen was received by the laboratory/performing organization. Supports turnaround-time and traceability."

# A concise description of what this element means (e.g. for use in autogenerated summaries).
#: StructureDefinition.element.Specimen.parent/short
msgid "Reference to the parent specimen when this specimen is derived/aliquoted from another specimen."
msgstr "Reference to the parent specimen when this specimen is derived/aliquoted from another specimen."

# A concise description of what this element means (e.g. for use in autogenerated summaries).
#: StructureDefinition.element.Specimen.request/short
msgid "Order/request that triggered the specimen collection. Enables linking specimen to ordered tests/services."
msgstr "Order/request that triggered the specimen collection. Enables linking specimen to ordered tests/services."

# A concise description of what this element means (e.g. for use in autogenerated summaries).
#: StructureDefinition.element.Specimen.combined/short
msgid "Whether the container holds a pooled/combined specimen from multiple collection events or sources (if applicable)."
msgstr "Whether the container holds a pooled/combined specimen from multiple collection events or sources (if applicable)."

# A concise description of what this element means (e.g. for use in autogenerated summaries).
#: StructureDefinition.element.Specimen.role/short
msgid "Role of this container in the overall specimen . Supports lab handling and result association."
msgstr "Role of this container in the overall specimen . Supports lab handling and result association."

# A concise description of what this element means (e.g. for use in autogenerated summaries).
#: StructureDefinition.element.Specimen.collection.collector/short
msgid "Practitioner who collected the specimen."
msgstr "Practitioner who collected the specimen."

# A concise description of what this element means (e.g. for use in autogenerated summaries).
#: StructureDefinition.element.Specimen.collection.collected[x]/short
msgid "Date/time (or period) when the specimen was collected. Used for clinical interpretation and lab timing."
msgstr "Date/time (or period) when the specimen was collected. Used for clinical interpretation and lab timing."

# A concise description of what this element means (e.g. for use in autogenerated summaries).
#: StructureDefinition.element.Specimen.collection.duration/short
msgid "Duration of the collection process (e.g., timed urine collection). Important for correct result calculation/interpretation."
msgstr "Duration of the collection process (e.g., timed urine collection). Important for correct result calculation/interpretation."

# A concise description of what this element means (e.g. for use in autogenerated summaries).
#: StructureDefinition.element.Specimen.collection.quantity/short
msgid "Amount/volume of specimen collected. Used for adequacy checks and processing requirements."
msgstr "Amount/volume of specimen collected. Used for adequacy checks and processing requirements."

# A concise description of what this element means (e.g. for use in autogenerated summaries).
#: StructureDefinition.element.Specimen.collection.bodySite/short
msgid "Anatomical site from which the specimen was collected."
msgstr "Anatomical site from which the specimen was collected."

# A concise description of what this element means (e.g. for use in autogenerated summaries).
#: StructureDefinition.element.Specimen.collection.fastingStatus[x]/short
msgid "Patient fasting status at collection time (or relevant clinical information affecting interpretation)."
msgstr "Patient fasting status at collection time (or relevant clinical information affecting interpretation)."

