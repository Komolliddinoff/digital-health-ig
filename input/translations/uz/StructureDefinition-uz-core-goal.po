
# A natural language name identifying the structure definition. This name should be usable as an identifier for the module by machine processing applications such as code generation.
#: StructureDefinition.name
msgid "UZCoreGoal"
msgstr "UZCoreGoal"

# A short, descriptive, user-friendly title for the structure definition.
#: StructureDefinition.title
msgid "UZ Core Goal"
msgstr "UZ Core Goal"

# The name of the organization or individual responsible for the release and ongoing maintenance of the structure definition.
#: StructureDefinition.publisher
msgid "Ministry of Health of the Republic of Uzbekistan"
msgstr "Ministry of Health of the Republic of Uzbekistan"

# The name of an individual to contact.
#: StructureDefinition.contact.name
msgid "Ministry of Health of the Republic of Uzbekistan"
msgstr "Ministry of Health of the Republic of Uzbekistan"

# A name for the specification that is being mapped to.
#: StructureDefinition.mapping.w5/name
msgid "FiveWs Pattern Mapping"
msgstr "FiveWs Pattern Mapping"

# A name for the specification that is being mapped to.
#: StructureDefinition.mapping.v2/name
msgid "HL7 V2 Mapping"
msgstr "HL7 V2 Mapping"

# A name for the specification that is being mapped to.
#: StructureDefinition.mapping.rim/name
msgid "RIM Mapping"
msgstr "RIM Mapping"

# A concise description of what this element means (e.g. for use in autogenerated summaries).
#: StructureDefinition.element.Goal.identifier/short
msgid "The external identifier of this goal (for example, the number in the database of an insurance company or another clinic)."
msgstr "The external identifier of this goal (for example, the number in the database of an insurance company or another clinic)."

# A concise description of what this element means (e.g. for use in autogenerated summaries).
#: StructureDefinition.element.Goal.lifecycleStatus/short
msgid "At what stage of planning is the goal.

Options: proposed, planned, accepted, active (in progress), suspended, completed, canceled, input error, rejected."
msgstr "At what stage of planning is the goal.

Options: proposed, planned, accepted, active (in progress), suspended, completed, canceled, input error, rejected."

# A concise description of what this element means (e.g. for use in autogenerated summaries).
#: StructureDefinition.element.Goal.achievementStatus/short
msgid "Assessment of progress (how are things going?).

Options: in progress, improving, deteriorating, unchanged, achieved, maintained, not achieved, no progress, unreachable."
msgstr "Assessment of progress (how are things going?).

Options: in progress, improving, deteriorating, unchanged, achieved, maintained, not achieved, no progress, unreachable."

# A concise description of what this element means (e.g. for use in autogenerated summaries).
#: StructureDefinition.element.Goal.category/short
msgid "Grouping goals by type.

Examples: Treatment, Diet, Behavioral therapy, Nursing."
msgstr "Grouping goals by type.

Examples: Treatment, Diet, Behavioral therapy, Nursing."

# A concise description of what this element means (e.g. for use in autogenerated summaries).
#: StructureDefinition.element.Goal.continuous/short
msgid "Check box (Yes/No). If the answer is Yes, it means that after achieving the goal, efforts do not stop, but are constantly required to maintain the result (for example, «maintain a diet» for life)."
msgstr "Check box (Yes/No). If the answer is Yes, it means that after achieving the goal, efforts do not stop, but are constantly required to maintain the result (for example, «maintain a diet» for life)."

# A concise description of what this element means (e.g. for use in autogenerated summaries).
#: StructureDefinition.element.Goal.priority/short
msgid "The importance of this goal.

Options: high, medium, low."
msgstr "The importance of this goal.

Options: high, medium, low."

# A concise description of what this element means (e.g. for use in autogenerated summaries).
#: StructureDefinition.element.Goal.description/short
msgid "A text or code that tells you exactly what the goal is."
msgstr "A text or code that tells you exactly what the goal is."

# A concise description of what this element means (e.g. for use in autogenerated summaries).
#: StructureDefinition.element.Goal.subject/short
msgid "The person for whom this goal is set (Patient, Group of people or Organization)."
msgstr "The person for whom this goal is set (Patient, Group of people or Organization)."

# A concise description of what this element means (e.g. for use in autogenerated summaries).
#: StructureDefinition.element.Goal.start[x]/short
msgid "When the work on the goal begins."
msgstr "When the work on the goal begins."

# A concise description of what this element means (e.g. for use in autogenerated summaries).
#: StructureDefinition.element.Goal.target/short
msgid "A container for specific numbers or conditions that we strive for.

+ Rule: Goal.target.measure is required if Goal.target.detail is populated."
msgstr "A container for specific numbers or conditions that we strive for.

+ Rule: Goal.target.measure is required if Goal.target.detail is populated."

# A concise description of what this element means (e.g. for use in autogenerated summaries).
#: StructureDefinition.element.Goal.target.measure/short
msgid "What parameter are we monitoring? (Parameter code, for example, «Body weight» or «Blood glucose»)."
msgstr "What parameter are we monitoring? (Parameter code, for example, «Body weight» or «Blood glucose»)."

# A concise description of what this element means (e.g. for use in autogenerated summaries).
#: StructureDefinition.element.Goal.target.detail[x]/short
msgid "The figure itself or the state that needs to be achieved."
msgstr "The figure itself or the state that needs to be achieved."

# A concise description of what this element means (e.g. for use in autogenerated summaries).
#: StructureDefinition.element.Goal.target.due[x]/short
msgid "The deadline for achieving the indicator.
May be:
• DueDate: A specific date (by 01.01.2024).
• dueDuration: Duration (2 weeks after the start)."
msgstr "The deadline for achieving the indicator.
May be:
• DueDate: A specific date (by 01.01.2024).
• dueDuration: Duration (2 weeks after the start)."

# A concise description of what this element means (e.g. for use in autogenerated summaries).
#: StructureDefinition.element.Goal.statusDate/short
msgid "The calendar date when the lifeCycleStatus was updated."
msgstr "The calendar date when the lifeCycleStatus was updated."

# A concise description of what this element means (e.g. for use in autogenerated summaries).
#: StructureDefinition.element.Goal.statusReason/short
msgid "The reason for the current status."
msgstr "The reason for the current status."

# A concise description of what this element means (e.g. for use in autogenerated summaries).
#: StructureDefinition.element.Goal.source/short
msgid "Who came up with/set this goal?"
msgstr "Who came up with/set this goal?"

# A concise description of what this element means (e.g. for use in autogenerated summaries).
#: StructureDefinition.element.Goal.addresses/short
msgid "Medical problems for which the goal is set."
msgstr "Medical problems for which the goal is set."

# A concise description of what this element means (e.g. for use in autogenerated summaries).
#: StructureDefinition.element.Goal.note/short
msgid "Comments about the goal."
msgstr "Comments about the goal."

# A concise description of what this element means (e.g. for use in autogenerated summaries).
#: StructureDefinition.element.Goal.outcome/short
msgid "What result was achieved regarding this goal? Free-text in concept.text, SNOMED, or custom codes may be used."
msgstr "What result was achieved regarding this goal? Free-text in concept.text, SNOMED, or custom codes may be used."

